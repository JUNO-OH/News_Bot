# Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# Kakao Developers
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_REDIRECT_URI=http://localhost:8080/oauth
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token

# Optional: Naver News Search API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Local/test options
DRY_RUN=false
SEND_KAKAO=true

# Android 위젯/웹 브리핑용
GITHUB_PAGES_BASE_URL=https://YOUR_GITHUB_ID.github.io/morning_routine_bot
SEND_KAKAO=false
