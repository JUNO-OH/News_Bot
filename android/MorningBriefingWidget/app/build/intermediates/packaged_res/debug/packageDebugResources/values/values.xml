<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="widget_bg">#0B1220</color>
    <color name="widget_muted">#A9B4C7</color>
    <color name="widget_text">#F8FAFC</color>
    <string name="app_name">Morning Briefing</string>
    <string name="briefing_json_url">https://juno-oh.github.io/News_Bot/latest.json</string>
    <string name="briefing_page_url">https://juno-oh.github.io/News_Bot/latest.html</string>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#090F1C</item>
        <item name="android:statusBarColor">#090F1C</item>
    </style>
    <style name="MarketChange">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#9AA4B2</item>
        <item name="android:textSize">9sp</item>
    </style>
    <style name="MarketColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingRight">2dp</item>
    </style>
    <style name="MarketLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#A9B4C7</item>
        <item name="android:textSize">10sp</item>
    </style>
    <style name="MarketValue">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#F8FAFC</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>